generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                     String   @id @default(cuid())
  email                  String   @unique
  passwordHash           String
  role                   String   @default("STUDENT") // ADMIN | STUDENT
  firstName              String
  lastName               String
  gender                 String? // MALE | FEMALE
  whatsappCountryCode    String?
  whatsappNationalNumber String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  articles   Article[]   @relation("AuthorArticles")
  views      ArticleView[]
  categories Category[]
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String
  sortOrder Int       @default(0)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  articles  Article[]

  @@unique([authorId, slug])
}

model Article {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  videoUrl        String?
  audioUrl        String?
  content         String
  contentFormat   String    @default("MARKDOWN") // MARKDOWN (standard); LATEX = legacy rows only
  publishName     String
  authorIconUrl   String?
  socialTwitter   String?
  socialYoutube   String?
  socialInstagram String?
  socialFacebook  String?
  socialLinkedin  String?
  published       Boolean   @default(false)
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  authorId        String
  author          User      @relation("AuthorArticles", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  views ArticleView[]

  @@index([categoryId])
  @@index([published, categoryId])
}

model ArticleView {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@index([articleId])
  @@index([studentId])
}
